{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
<div class="container mt-5">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <h1>{{ user.firstName }} {{ user.lastName }}</h1>
    <p class="text-muted">{{ user.pseudo }}#{{ user.pseudoId }}</p>

    <div class="profile-links mt-3">
        <a href="{{ path('app_user_edit') }}" class="btn btn-secondary">Modifier mon profil</a>
        <a href="{{ path('app_logout') }}" class="btn btn-secondary">Déconnexion</a>
        <a href="{{ path('app_user_delete') }}" class="btn btn-danger">Supprimer mon compte</a>
    </div>

    <section class="profile-section mt-5">
        <div class="profile-section-header">
            <h2>Mes recettes</h2>
            <a href="{{ path('app_recipe_new') }}" class="btn btn-primary btn-sm">+ Créer</a>
        </div>

        {% if recipes is empty %}
            <p class="text-muted">Vous n'avez pas encore créé de recette.</p>
        {% else %}
            <ul class="profile-recipe-list">
                {% for recipe in recipes %}
                    <li>
                        <a href="{{ path('app_recipe_show', { id: recipe.id }) }}">{{ recipe.title }}</a>
                        <a href="{{ path('app_recipe_edit', { id: recipe.id }) }}" class="btn btn-sm btn-secondary">Modifier</a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>
</div>
{% endblock %}
