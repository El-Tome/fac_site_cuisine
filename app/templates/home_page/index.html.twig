{% extends 'base.html.twig' %}

{% block title %}Accueil — Site de cuisine{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/css/home.css">
{% endblock %}

{% block body %}
<div class="container home-page">

    <form method="get" action="{{ path('app_home_page') }}" class="home-search-form">
        <input
            type="search"
            name="q"
            value="{{ query }}"
            placeholder="Rechercher une recette ou un auteur…"
            aria-label="Rechercher une recette"
            class="home-search-input"
            autocomplete="off"
        >
        <button type="submit" class="home-search-btn">Rechercher</button>
    </form>

    {% if query %}
        <p class="home-search-hint">
            Résultats pour <strong>{{ query }}</strong>
            — <a href="{{ path('app_home_page') }}">Effacer</a>
        </p>
    {% endif %}

    {% if hero is null and recipes is empty %}
        <div class="home-empty">
            <p>{% if query %}Aucune recette ne correspond à votre recherche.{% else %}Aucune recette pour l'instant.{% endif %}</p>
            {% if is_granted('ROLE_EDITOR') %}
                <a href="{{ path('app_recipe_new') }}" class="btn btn-primary">Créer la première recette</a>
            {% endif %}
        </div>
    {% else %}

        {# ===== Hero ===== #}
        {% if hero is not null %}
            <div class="hero-wrapper">
                {% include '_partial/_hero.html.twig' %}
            </div>
        {% endif %}

        {# ===== Grid ===== #}
        {% if recipes is not empty %}
            <h2 class="section-heading">{{ query ? 'Recettes trouvées' : 'D\'autres recettes' }}</h2>
            <div class="recipe-grid">
                {% for recipe in recipes %}
                    <a href="{{ path('app_recipe_show', { id: recipe.id }) }}" class="recipe-card">
                        <div class="recipe-card__image-wrapper">
                            {% if recipe.imageUrl %}
                                <img src="{{ recipe.imageUrl }}" alt="{{ recipe.title }}" class="recipe-card__image">
                            {% endif %}
                            <span class="recipe-card__diff">{{ recipe.difficulty.getLabel() }}</span>
                        </div>
                        <div class="recipe-card__body">
                            <span class="recipe-card__title">{{ recipe.title }}</span>
                            <span class="recipe-card__description">{{ recipe.description }}</span>
                            <div class="recipe-card__meta">
                                <span>⏱ {{ recipe.prepTime }} min</span>
                                <span>🍽 {{ recipe.servings }} pers.</span>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}

    {% endif %}
</div>
{% endblock %}
