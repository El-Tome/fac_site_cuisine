{% extends 'base.html.twig' %}

{% block title %}Accueil — Site de cuisine{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/css/home.css">
{% endblock %}

{% block body %}
<div class="container home-page">

    {% if hero is null %}
        <div class="home-empty">
            <p>Aucune recette pour l'instant.</p>
            {% if is_granted('ROLE_EDITOR') %}
                <a href="{{ path('app_recipe_new') }}" class="btn btn-primary">Créer la première recette</a>
            {% endif %}
        </div>
    {% else %}

        {# ===== Hero ===== #}
        <a href="{{ path('app_recipe_show', { id: hero.id }) }}" class="hero-card">
            {% if hero.imageUrl %}
                <img src="{{ hero.imageUrl }}" alt="{{ hero.title }}" class="hero-card__image">
            {% endif %}
            <div class="hero-card__overlay"></div>
            <div class="hero-card__body">
                <span class="hero-card__label">{{ hero.difficulty.getLabel() }}</span>
                <h1 class="hero-card__title">{{ hero.title }}</h1>
                <p class="hero-card__description">{{ hero.description }}</p>
                <div class="hero-card__meta">
                    <span>⏱ {{ hero.prepTime }} min de préparation</span>
                    {% if hero.cookTime %}
                        <span>🔥 {{ hero.cookTime }} min de cuisson</span>
                    {% endif %}
                    <span>🍽 {{ hero.servings }} personne{{ hero.servings > 1 ? 's' : '' }}</span>
                </div>
                <span class="hero-card__cta">Voir la recette</span>
            </div>
        </a>

        {# ===== Grid ===== #}
        {% if recipes is not empty %}
            <h2 class="section-heading">D'autres recettes</h2>
            <div class="recipe-grid">
                {% for recipe in recipes %}
                    <a href="{{ path('app_recipe_show', { id: recipe.id }) }}" class="recipe-card">
                        <div class="recipe-card__image-wrapper">
                            {% if recipe.imageUrl %}
                                <img src="{{ recipe.imageUrl }}" alt="{{ recipe.title }}" class="recipe-card__image">
                            {% endif %}
                            <span class="recipe-card__diff">{{ recipe.difficulty.getLabel() }}</span>
                        </div>
                        <div class="recipe-card__body">
                            <span class="recipe-card__title">{{ recipe.title }}</span>
                            <span class="recipe-card__description">{{ recipe.description }}</span>
                            <div class="recipe-card__meta">
                                <span>⏱ {{ recipe.prepTime }} min</span>
                                <span>🍽 {{ recipe.servings }} pers.</span>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}

    {% endif %}
</div>
{% endblock %}
