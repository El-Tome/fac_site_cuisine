{% extends 'base.html.twig' %}

{% block title %}{{ recipe.title }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/css/show.css">
{% endblock %}

{% block body %}
<div class="container mt-5 recipe-show-page">

    {# ===== Hero ===== #}
    <div class="recipe-hero">
        {% if recipe.imageUrl %}
            <img src="{{ recipe.imageUrl }}" alt="{{ recipe.title }}" class="recipe-hero__image">
        {% endif %}
        <div class="recipe-hero__overlay"></div>
        <div class="recipe-hero__content">
            <h1 class="recipe-hero__title">{{ recipe.title }}</h1>
            <div class="recipe-hero__pills">
                <span class="recipe-pill">{{ recipe.difficulty.getLabel() }}</span>
                <span class="recipe-pill">⏱ {{ recipe.prepTime }} min de prépa</span>
                {% if recipe.cookTime %}
                    <span class="recipe-pill">🔥 {{ recipe.cookTime }} min de cuisson</span>
                {% endif %}
                <span class="recipe-pill">🍽 {{ recipe.servings }} personne{{ recipe.servings > 1 ? 's' : '' }}</span>
                <span class="recipe-pill recipe-pill--author">Par {{ recipe.author.pseudo }}</span>
            </div>
        </div>
    </div>

    {# ===== Two-column layout ===== #}
    <div class="recipe-layout">

        {# Left: description + steps #}
        <div>
            <p class="recipe-description">{{ recipe.description }}</p>

            {% if recipe.recipeSteps is not empty %}
                <h2 class="recipe-block-title">Étapes</h2>
                <div class="recipe-steps">
                    {% for step in recipe.recipeSteps|sort((a, b) => a.step <=> b.step) %}
                        <div class="recipe-step">
                            <div class="recipe-step__number">{{ loop.index }}</div>
                            <div class="recipe-step__body">
                                <div class="recipe-step__title">{{ step.title }}</div>
                                {% if step.explanation %}
                                    <p class="recipe-step__explanation">{{ step.explanation }}</p>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {# Right: ingredients sticky card #}
        <aside>
            <div class="ingredients-card">
                <h2 class="ingredients-card__title">
                    Ingrédients
                    {% if recipe.recipeIngredients is not empty %}
                        <small style="font-weight:400;color:#9ca3af;font-size:0.78rem;">
                            ({{ recipe.servings }} pers.)
                        </small>
                    {% endif %}
                </h2>
                {% if recipe.recipeIngredients is empty %}
                    <p style="color:#9ca3af;font-size:0.9rem;margin:0">Aucun ingrédient renseigné.</p>
                {% else %}
                    <ul class="ingredients-list">
                        {% for ri in recipe.recipeIngredients %}
                            <li>
                                <div class="ingredient-row">
                                    <span class="ingredient-qty">{{ ri.quantity }} {{ ri.unit.value }}</span>
                                    <span class="ingredient-name">{{ ri.ingredient.nom }}</span>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </aside>

    </div>

    {# ===== Actions ===== #}
    <div class="recipe-actions">
        <a href="{{ path('app_home_page') }}" class="btn btn-secondary">← Retour</a>

        {% if app.user %}
            <button id="like-btn"
                    class="btn-like {% if isLiked %}liked{% endif %}"
                    data-recipe-id="{{ recipe.id }}"
                    data-token="{{ csrf_token('like-recipe-' ~ recipe.id) }}">
                <span class="like-heart">♥</span>
                <span id="like-count">{{ likeCount }}</span>
            </button>
        {% else %}
            <span class="btn-like-display">♥ {{ likeCount }}</span>
        {% endif %}

        {% if app.user and app.user == recipe.author %}
            <a href="{{ path('app_recipe_edit', { id: recipe.id }) }}" class="btn btn-primary">Modifier</a>
            <form method="post" action="{{ path('app_recipe_delete', { id: recipe.id }) }}"
                  onsubmit="return confirm('Supprimer définitivement cette recette ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete-recipe-' ~ recipe.id) }}">
                <button type="submit" class="btn btn-danger">Supprimer</button>
            </form>
        {% endif %}
    </div>

</div>
{% endblock %}

{% block javascripts %}
{% if app.user %}
<script src="/js/recipe-like.js" defer></script>
{% endif %}
{% endblock %}
