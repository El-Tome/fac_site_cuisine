{% extends 'base.html.twig' %}

{% block title %}Gestion des ingrédients{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/css/recipe-form.css">
{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="manage-header">
        <h1>Ingrédients</h1>
        <div class="manage-header-actions">
            <a href="{{ path('app_ingredient_category_index') }}" class="btn btn-secondary">Catégories</a>
            <a href="{{ path('app_ingredient_new') }}" class="btn btn-primary">+ Ajouter un ingrédient</a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {% if ingredients is empty %}
        <p class="text-muted">Aucun ingrédient pour l'instant.</p>
    {% else %}
        <table class="ingredient-table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Catégories</th>
                    <th>Utilisé dans</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for ingredient in ingredients %}
                    <tr>
                        <td>{{ ingredient.nom }}</td>
                        <td>
                            {% for cat in ingredient.categories %}
                                <span class="badge">{{ cat.name }}</span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endfor %}
                        </td>
                        <td>{{ ingredient.ingredientUsage|length }} recette(s)</td>
                        <td class="table-actions">
                            <a href="{{ path('app_ingredient_edit', { id: ingredient.id }) }}" class="btn btn-sm btn-secondary">Modifier</a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <form method="post" action="{{ path('app_ingredient_delete', { id: ingredient.id }) }}"
                                      style="display:inline"
                                      onsubmit="return confirm('Supprimer « {{ ingredient.nom }} » ? Cette action est irréversible.')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete-ingredient-' ~ ingredient.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
{% endblock %}
