{% extends 'base.html.twig' %}

{% block title %}Catégories d'ingrédients{% endblock %}

{% block body %}
<div class="container mt-5">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
        <h1>Catégories d'ingrédients</h1>
        <a href="{{ path('app_ingredient_category_new') }}" class="btn btn-primary">+ Ajouter une catégorie</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% if categories is empty %}
        <p>Aucune catégorie pour l'instant.</p>
    {% else %}
        <table class="ingredient-table">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Nombre d'ingrédients</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for category in categories %}
                    <tr>
                        <td>{{ category.name }}</td>
                        <td>{{ category.ingredients|length }}</td>
                        <td>
                            <a href="{{ path('app_ingredient_category_edit', { id: category.id }) }}" class="btn btn-sm btn-secondary">Modifier</a>

                            <form method="post" action="{{ path('app_ingredient_category_delete', { id: category.id }) }}"
                                  style="display:inline"
                                  onsubmit="return confirm('Supprimer « {{ category.name }} » ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-category-' ~ category.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <div class="mt-4">
        <a href="{{ path('app_ingredient_index') }}" class="btn btn-secondary">← Retour aux ingrédients</a>
    </div>
</div>
{% endblock %}
